{
  "name": "@matanelcohen/openspace-mcp-server",
  "version": "0.4.2",
  "type": "module",
  "description": "MCP server for the openspace.ai squad — exposes squad tools and resources via Model Context Protocol",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openspace-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "start:sse": "node dist/sse.js",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@matanelcohen/openspace-shared": "workspace:*",
    "dotenv": "^16.4.0",
    "express": "^5.1.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Matan Cohen",
  "repository": {
    "type": "git",
    "url": "https://github.com/matanelcohen/openspace-for-ai-squad.git",
    "directory": "packages/mcp-server"
  }
}
