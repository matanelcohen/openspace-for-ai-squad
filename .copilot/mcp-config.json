{
  "mcpServers": {
    "openspace-stdio": {
      "command": "npx",
      "args": ["--yes", "-w", "packages/mcp-server", "openspace-mcp"],
      "env": {
        "OPENSPACE_API_URL": "http://localhost:3001"
      }
    },
    "openspace-sse": {
      "type": "sse",
      "url": "http://localhost:3002/sse",
      "env": {
        "OPENSPACE_API_URL": "http://localhost:3001"
      }
    },
    "EXAMPLE-github": {
      "command": "npx",
      "args": ["-y", "@anthropic/github-mcp-server"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
