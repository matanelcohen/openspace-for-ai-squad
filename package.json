{
  "name": "@matanelcohen/openspace-ai",
  "version": "0.2.0",
  "description": "Visual workspace manager for Squad SDK — create, manage, and collaborate with AI agent teams",
  "keywords": [
    "ai",
    "agents",
    "squad",
    "squad-sdk",
    "copilot",
    "team-management",
    "llm",
    "rag",
    "openspace"
  ],
  "homepage": "https://matanelcohen.github.io/openspace-for-ai-squad/",
  "repository": {
    "type": "git",
    "url": "https://github.com/matanelcohen/openspace-for-ai-squad.git"
  },
  "license": "MIT",
  "author": "Matan Cohen",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "openspace": "./bin/openspace.mjs",
    "openspace-mcp": "./packages/mcp-server/dist/cli.js"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "e2e": "playwright test",
    "prepare": "husky",
    "prepublishOnly": "pnpm build"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,html,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/eslint__js": "^9.14.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
