# openspace.ai — Root Environment Variables
# Copy this file to .env and fill in values.
# App-specific variables are in apps/api/.env.example and apps/web/.env.example.

# ──────────────────────────────────────────
# API Server
# ──────────────────────────────────────────

API_PORT=3001
API_HOST=0.0.0.0

# ──────────────────────────────────────────
# Web Frontend
# ──────────────────────────────────────────

NEXT_PUBLIC_API_URL=http://localhost:3001

# ──────────────────────────────────────────
# Squad Directory
# ──────────────────────────────────────────

# Path to the .squad/ directory (source of truth)
SQUAD_DIR=.squad

# ──────────────────────────────────────────
# AI Provider
# ──────────────────────────────────────────

# AI_PROVIDER=copilot-sdk
# COPILOT_MODEL=claude-opus-4.6
# COPILOT_FALLBACK_MODEL=gpt-4o
# COPILOT_CLI_URL=localhost:3100

# ──────────────────────────────────────────
# OpenAI (required for voice & agent chat)
# ──────────────────────────────────────────

# OPENAI_API_KEY=sk-...
