# openspace.ai API — Environment Variables
# Copy this file to .env and fill in values.

# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────

# Port the Fastify server listens on
API_PORT=3001

# Host to bind to (0.0.0.0 for all interfaces)
API_HOST=0.0.0.0

# Allowed CORS origins (comma-separated list of allowed origins)
# e.g. https://app.openspace.ai,https://staging.openspace.ai
# If unset or '*', defaults to localhost only in dev, rejects all in production.
CORS_ORIGIN=http://localhost:3000

# ──────────────────────────────────────────
# Squad Directory
# ──────────────────────────────────────────

# Path to the .squad/ directory (source of truth for all data)
# Can be relative (to repo root) or absolute
SQUAD_DIR=.squad

# ──────────────────────────────────────────
# OpenAI (Voice & Chat)
# ──────────────────────────────────────────

# OpenAI API key — required for voice chat (Realtime API) and agent responses
# OPENAI_API_KEY=sk-...

# OpenAI model for agent chat responses (default: gpt-4o)
# OPENAI_CHAT_MODEL=gpt-4o

# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────

# SQLite database path (rebuildable cache, auto-created if missing)
# DB_PATH=.squad/.cache/openspace.db

# ──────────────────────────────────────────
# Telemetry (OTLP)
# ──────────────────────────────────────────

# OTLP endpoint for the Copilot CLI and our own OTel SDK.
# Defaults to the API server itself (http://localhost:3001).
# COPILOT_OTLP_ENDPOINT=http://localhost:3001
