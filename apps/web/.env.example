# openspace.ai Web — Environment Variables
# Copy this file to .env.local and fill in values.

# ──────────────────────────────────────────
# API Connection
# ──────────────────────────────────────────

# URL of the openspace.ai API server (Fastify backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL for real-time events (defaults to API_URL with ws:// protocol)
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ──────────────────────────────────────────
# Voice (OpenAI Realtime API)
# ──────────────────────────────────────────

# OpenAI API key for voice features (Realtime API for STT + TTS)
# Required for voice chat functionality
# NEXT_PUBLIC_OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────
# Development
# ──────────────────────────────────────────

# Next.js port (default: 3000)
# PORT=3000
