.squad/
.copilot/
.github/

# Database & cache
*.db
*.db-journal
*.sqlite
.cache/

# Environment & secrets
.env
.env.*
!.env.example

# IDE & OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Build artifacts & deps
node_modules/
dist/
.next/
.turbo/
coverage/
test-results/
playwright-report/

# Test files
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
e2e/
vitest.config.ts
playwright.config.ts

# Dev config
turbo.json
pnpm-workspace.yaml
pnpm-lock.yaml
tsconfig.json
eslint.config.mjs
.prettierrc
.prettierignore
.husky/

# Squad SDK config (project-specific)
squad.config.ts
squad.config.js

# Landing page (served via GitHub Pages)
docs/

